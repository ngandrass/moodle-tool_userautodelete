{{!
    @template tool_userautodelete/workflows

    Displays a single workflow.

    Example context (json):
    {
        "id": 1,
        "title": "Workflow 1",
        "description": "Description of workflow 1",
        "sort": 1,
        "active": true,
        "timecreated": 1700000000,
        "timemodified": 1700000000,
        "createdby": {
            "id": 2,
            "fullname": "Admin User",
            "profileurl": "https://mymoodle/user/profile.php?id=2"
        },
        "modifiedby": {
            "id": 2,
            "fullname": "Admin User",
            "profileurl": "https://mymoodle/user/profile.php?id=2"
        },
        "stepcount": 1,
        "steps": [
            {
                "id": 1,
                "title": "Step 1",
                "description": "Description of step 1",
                "sort": 1,
                "isfirst": true,
                "filters": [
                    {
                        "id": 1,
                        "name:": "auth",
                        "title": "Authentication method",
                        "details": "manual, email"
                    }
                ],
                "actions": [
                    {
                        "id": 1,
                        "name:": "delete",
                        "title": "Delete user",
                        "details": ""
                    }
                ]
                "processes": {
                    "active": 2,
                    "finished": 8,
                    "total": 10
                }
            }
        ],
        "isediting": true,
        "canbeactivated": false,
        "actionurls": {
            "activate": "https://foo.bar/baz",
            "delete": "https://foo.bar/baz",
            "edit": "https://foo.bar/baz",
        }
    }
}}

<h2>{{#str}} manage_workflow, tool_userautodelete {{/str}}</h2>
<p>{{#str}} manage_workflow_desc, tool_userautodelete {{/str}}</p>

<div class="container">
    <div class="row mb-5">
        <div class="col-sm-12">
            <div class="card m-auto" style="width: fit-content; min-width: 580px;">
                <div class="card-header text-white bg-primary">
                    <b>{{title}}</b><br>
                    <span>{{description}}</span>
                </div>
                <ul class="list-group list-group-flush">
                    <li class="list-group-item">
                        <b>{{#str}} status {{/str}}:</b>
                        {{#active}}
                            <span class="badge badge-success">{{#str}} active {{/str}}</span>
                        {{/active}}
                        {{^active}}
                            <span class="badge badge-secondary">{{#str}} disabled, admin {{/str}}</span>
                        {{/active}}
                    </li>
                    <li class="list-group-item">
                        <b>{{#str}} lastmodified {{/str}}:</b>
                        <span>
                            {{#userdate}} {{timemodified}}, {{#str}} strftimedatetime, core_langconfig {{/str}} {{/userdate}}
                        </span>
                        (<a href="{{{modifiedby.profileurl}}}">{{modifiedby.fullname}}</a>)
                    </li>
                </ul>
            </div>
        </div>
    </div>

    {{#steps}}
        {{^isfirst}}
            <div class="row py-3 text-center">
                <div class="col-sm-12">
                    <i class="fa-solid fa-arrow-down-long fa-2x"></i>
                </div>
            </div>
        {{/isfirst}}
        <div class="row">
            <div class="col-sm-12 text-center">
                <div class="card m-auto" style="width: fit-content; min-width: 420px;">
                    <div class="card-header d-flex flex-row align-items-center justify-content-between">
                        <div class="border-end pe-2 me-2">
                            <i class="fa-solid fa-hashtag"></i>&nbsp;<b>{{sort}}</b>
                        </div>
                        <div class="flex-grow-1 text-left">
                            <b>{{title}}</b>
                        </div>
                        <div class="ms-2 ps-2">
                            {{#description}}
                                <i
                                    class="icon fa-solid fa-circle-info fa-lg"
                                    title="{{description}}"
                                    data-toggle="tooltip"
                                    data-title="{{description}}"
                                    data-bs-toggle="tooltip"
                                    data-bs-title="{{description}}"
                                ></i>
                            {{/description}}
                            {{#isediting}}
                                <a
                                    href="#TODO"
                                    class="link-success"
                                    title="{{#str}} edit {{/str}}"
                                    data-toggle="tooltip"
                                    data-placement="top"
                                    data-title="{{#str}} edit {{/str}}"
                                    data-bs-toggle="tooltip"
                                    data-bs-placement="top"
                                    data-bs-title="{{#str}} edit {{/str}}"
                                >
                                    <i class="fa-solid fa-pencil fa-lg"></i>
                                </a>
                            {{/isediting}}
                        </div>
                    </div>
                    <div class="card-body">
                        <div>
                            <div class="mb-2">
                                <span class="border rounded-pill px-3 py-1 font-weight-bold">
                                    <i class="fa-solid fa-filter"></i>&nbsp;
                                    {{#str}} filters, tool_userautodelete {{/str}}
                                </span>
                            </div>
                            {{#filters}}
                                <a
                                    class="btn btn-outline-primary px-3 py-2 m-1 {{^isediting}} disabled {{/isediting}}"
                                    style="font-style: normal;"
                                    role="button"
                                    href="#"
                                    {{#isediting}}
                                        data-bs-toggle="tooltip"
                                        data-bs-placement="top"
                                        data-bs-title="{{#str}} edit_filter, tool_userautodelete {{/str}}"
                                        data-toggle="tooltip"
                                        data-placement="top"
                                        data-title="{{#str}} edit_filter, tool_userautodelete {{/str}}"
                                        title="{{#str}} edit_filter, tool_userautodelete {{/str}}"
                                    {{/isediting}}
                                >
                                    <div>
                                        <div class="font-weight-bold">
                                            {{title}}
                                        </div>
                                        {{#details}}
                                            <div>
                                                {{#shortentext}} 32, {{details}} {{/shortentext}}
                                            </div>
                                        {{/details}}
                                    </div>
                                </a>
                            {{/filters}}
                            {{#isediting}}
                                <a
                                    class="btn btn-outline-primary btn-sm m-1"
                                    style="border-style: dashed;"
                                    role="button"
                                    href="#"
                                    data-bs-toggle="tooltip"
                                    data-bs-placement="top"
                                    data-bs-title="{{#str}} add_filter, tool_userautodelete {{/str}}"
                                    data-toggle="tooltip"
                                    data-placement="top"
                                    data-title="{{#str}} add_filter, tool_userautodelete {{/str}}"
                                    title="{{#str}} add_filter, tool_userautodelete {{/str}}"
                                >
                                    <i class="fa-solid fa-plus"></i>
                                </a>
                            {{/isediting}}
                        </div>
                        <hr>
                        <div>
                            <div class="mb-2">
                                <span class="border rounded-pill px-3 py-1 font-weight-bold">
                                    <i class="fa-solid fa-gears"></i>&nbsp;
                                    {{#str}} actions, tool_userautodelete {{/str}}
                                </span>
                            </div>
                            {{#actions}}
                                <a
                                    class="btn btn-outline-danger px-3 py-2 m-1 {{^isediting}} disabled {{/isediting}}"
                                    style="font-style: normal;"
                                    role="button"
                                    href="#"
                                    {{#isediting}}
                                        data-bs-toggle="tooltip"
                                        data-bs-placement="top"
                                        data-bs-title="{{#str}} edit_action, tool_userautodelete {{/str}}"
                                        data-toggle="tooltip"
                                        data-placement="top"
                                        data-title="{{#str}} edit_action, tool_userautodelete {{/str}}"
                                        title="{{#str}} edit_action, tool_userautodelete {{/str}}"
                                    {{/isediting}}
                                >
                                    <div>
                                        <div class="font-weight-bold">
                                            {{title}}
                                        </div>
                                        {{#details}}
                                            <div>
                                                {{#shortentext}} 32, {{details}} {{/shortentext}}
                                            </div>
                                        {{/details}}
                                    </div>
                                </a>
                            {{/actions}}
                            {{#isediting}}
                                <a
                                    class="btn btn-outline-danger btn-sm m-1"
                                    style="border-style: dashed;"
                                    role="button"
                                    href="#"
                                    data-bs-toggle="tooltip"
                                    data-bs-placement="top"
                                    data-bs-title="{{#str}} add_action, tool_userautodelete {{/str}}"
                                    data-toggle="tooltip"
                                    data-placement="top"
                                    data-title="{{#str}} add_action, tool_userautodelete {{/str}}"
                                    title="{{#str}} add_action, tool_userautodelete {{/str}}"
                                >
                                    <i class="fa-solid fa-plus"></i>
                                </a>
                            {{/isediting}}
                        </div>
                    </div>
                    <div class="card-footer text-muted">
                        <i class="fa-solid fa-user"></i>&nbsp;
                        {{#str}} active_processes, tool_userautodelete, {{processes.active}} {{/str}}
                    </div>
                </div>
            </div>
        </div>
    {{/steps}}
</div>

