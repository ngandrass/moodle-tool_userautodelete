{{!
    @template tool_userautodelete/modal/editstep

    A step editing modal.

    Example context (json):
    {
        "id": 1,
        "title": "My Step",
        "description": "It does the magic thing.",
        "submiturl": "https://foo.bar/baz",
    }
}}

<form action="{{{submiturl}}}" method="post">
    <div class="form-group">
        <div class="ps-2">
            <i class="fa-solid fa-heading pe-1"></i>
            <label for="step-{{id}}-title">{{#str}} title, tool_userautodelete {{/str}}</label>
        </div>
        <input type="text" name="title" class="form-control" id="step-{{id}}-title" value="{{title}}">
    </div>
    <div class="form-group">
        <div class="ps-2">
            <i class="fa-solid fa-circle-info pe-1"></i>
            <label for="step-{{id}}-description">{{#str}} description, tool_userautodelete {{/str}}</label>
        </div>
        <input type="text" name="description" class="form-control" id="step-{{id}}-description" value="{{description}}">
    </div>
</form>
