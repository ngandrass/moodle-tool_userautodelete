{{!
    @template tool_userautodelete/modal/step_processes

    Displays a table of user processes for a workflow step inside a modal.

    Example context (json):
    {
        "hasprocesses": true,
        "processes": [
            {
                "processid": 1,
                "userid": 42,
                "username": "jdoe",
                "fullname": "John Doe",
                "profileurl": "https://mymoodle/user/profile.php?id=42",
                "isactive": true,
                "isfinished": false,
                "isaborted": false,
                "lastaccess": 1700000000,
                "timecreated": 1699000000,
                "timemodified": 1700000000,
                "timemodifiedrel": "5 minutes ago"
            }
        ]
    }
}}

{{#hasprocesses}}
<div class="table-responsive">
    <table class="table table-sm table-hover mb-0">
        <thead>
            <tr>
                <th>{{#str}} id, tool_userautodelete {{/str}}</th>
                <th>{{#str}} user {{/str}}</th>
                <th>{{#str}} lastaccess {{/str}}</th>
                <th>{{#str}} state, tool_userautodelete {{/str}}</th>
                <th>{{#str}} in_step_since, tool_userautodelete {{/str}}</th>
            </tr>
        </thead>
        <tbody>
            {{#processes}}
            <tr>
                <td>{{processid}}</td>
                <td>
                    <a href="{{{profileurl}}}">{{fullname}} (ID: {{userid}})</a>
                </td>
                <td>
                    {{#lastaccess}}
                        {{#userdate}} {{lastaccess}}, {{#str}} strftimedatetime, core_langconfig {{/str}} {{/userdate}}
                    {{/lastaccess}}
                    {{^lastaccess}}
                        <span class="text-muted">{{#str}} never {{/str}}</span>
                    {{/lastaccess}}
                </td>
                <td>
                    {{#isactive}}
                        <span class="badge badge-success bg-success">
                            {{#str}} active {{/str}}
                        </span>
                    {{/isactive}}
                    {{#isfinished}}
                        <span class="badge badge-secondary bg-secondary">
                            {{#str}} finished, tool_userautodelete {{/str}}
                        </span>
                    {{/isfinished}}
                    {{#isaborted}}
                        <span class="badge badge-danger bg-danger">
                            {{#str}} aborted, tool_userautodelete {{/str}}
                        </span>
                    {{/isaborted}}
                </td>
                <td>
                    <span
                        class="text-nowrap"
                        title="{{#userdate}} {{timemodified}}, {{#str}} strftimedatetime, core_langconfig {{/str}} {{/userdate}}"
                        data-toggle="tooltip"
                        data-title="{{#userdate}} {{timecreated}}, {{#str}} strftimedatetime, core_langconfig {{/str}} {{/userdate}}"
                        data-bs-toggle="tooltip"
                        data-bs-title="{{#userdate}} {{timemodified}}, {{#str}} strftimedatetime, core_langconfig {{/str}} {{/userdate}}"
                    >
                        {{timemodifiedrel}}
                    </span>
                </td>
            </tr>
            {{/processes}}
        </tbody>
    </table>
</div>
{{/hasprocesses}}

{{^hasprocesses}}
<p class="text-center text-muted my-3">
    <i class="fa-solid fa-circle-info me-1"></i>
    {{#str}} step_processes_none, tool_userautodelete {{/str}}
</p>
{{/hasprocesses}}
