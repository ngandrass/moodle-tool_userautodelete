{{!
    @template tool_userautodelete/modal/addfilter

    An filter creation modal.

    Example context (json):
    {
        "stepid": 42,
        "filters": [
            {
                "pluginname": "lastaccess",
                "displayname": "Last Access",
                "iconclass": "fa-solid fa-clock",
                "addurlbase": "https://foo.bar/baz"
            },
            {
                "pluginname": "auth",
                "displayname": "Authentication method",
                "iconclass": "fa-solid fa-shield-halved",
                "addurlbase": "https://foo.bar/baz"
            }
        ]
    }
}}

<p class="text-center">
    {{#str}} add_filter_desc, tool_userautodelete {{/str}}
</p>
<div class="d-flex flex-wrap justify-content-center text-center">
    {{#filters}}
        <a
            href="{{{addurlbase}}}&stepid={{stepid}}"
            class="btn btn-outline-primary m-2 d-flex flex-column justify-content-center align-items-center"
            style="width: 128px; height: 128px;"
            role="button"
        >
            <div class="mb-3">
                <b>{{displayname}}</b>
            </div>
            <div>
                <i class="{{iconclass}} fa-2x"></i>
            </div>
        </a>
    {{/filters}}
</div>
